# Frontend env vars consumed by the code.
# Set these locally in .env.local (gitignored) and on Vercel for production.

# Backend API base URL.
# Production (recommended): use the relative path "/api/v1" so requests
# go through the Next.js rewrite in next.config.ts, which proxies to
# API_PROXY_TARGET. This keeps the browser same-origin with Vercel and
# means cookies, CORS, and CSRF "just work".
# Local dev: same value works because next.config.ts also reads
# API_PROXY_TARGET locally.
NEXT_PUBLIC_API_URL=/api/v1

# Backend origin used by:
#   1. The Next.js rewrite (next.config.ts) for /api/v1/:path*
#   2. The SSE streaming proxy (src/app/api/sse/[...path]/route.ts)
# Server-only — must NOT be prefixed with NEXT_PUBLIC_.
# Required: the SSE proxy throws at startup if this is missing.
API_PROXY_TARGET=https://your-backend.up.railway.app
